<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MediaPadderPage.MediaPadderPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:MediaPadderPage"
    xmlns:converters="using:CommunityToolkit.WinUI.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:WinUIShared.Controls"
    xmlns:timeline="using:Timeline"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter" />
        <converters:BoolToVisibilityConverter x:Name="BoolToNegatedVisibilityConverter" TrueValue="Collapsed" FalseValue="Visible"/>
        <converters:BoolToVisibilityConverter x:Name="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
        </Grid.ColumnDefinitions>
        <Grid Name="CanvasContainer" SizeChanged="CanvasContainer_OnSizeChanged">
            <Canvas x:Name="PaddingCanvas" Background="Red" HorizontalAlignment="Left" VerticalAlignment="Top">
                <Canvas.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform x:Name="ZoomTransform" ScaleX="1" ScaleY="1"/>
                        <TranslateTransform x:Name="PanTransform" X="0" Y="0"/>
                    </TransformGroup>
                </Canvas.RenderTransform>
                <Canvas x:Name="ContentCanvas" Background="Black" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Image Name="Image" Stretch="Fill" ImageOpened="Image_OnImageOpened" Visibility="{x:Bind isVideo, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=True}"/>
                    <MediaPlayerElement Name="Video" Stretch="Fill" SizeChanged="Video_OnSizeChanged" Visibility="{x:Bind isVideo, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </Canvas>
            </Canvas>
        </Grid>
        <timeline:VideoControls Grid.Column="0" Grid.Row="1" Height="50" MediaPlayer="{x:Bind Video.MediaPlayer}" CurrentTimeEditable="True" ShowFractionalSeconds="True"
                                Visibility="{x:Bind isVideo, Converter={StaticResource BoolToVisibilityConverter}}" Margin="10,0"/>
        <controls:ProcessManager Grid.Column="0" Grid.Row="2" x:Name="ProcessManager" State="{x:Bind viewModel.State, Mode=TwoWay}"
                                 Processor="{x:Bind padProcessor}" HardwareSelector="{x:Bind HardwareSelector}" OnlyPrimary="True" Padding="10"/>
        <Grid Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Padding="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollView Margin="0,0,0,10">
                <StackPanel Spacing="10">
                    <TextBlock Name="MediaName" Style="{StaticResource TitleTextBlockStyle}"/>
                    <Button HorizontalAlignment="Center" Click="GoBack">
                        <StackPanel Orientation="Horizontal">
                            <FontIcon Glyph="&#xE72B;" Margin="0,0,10,0" />
                            <TextBlock VerticalAlignment="Center">Go back</TextBlock>
                        </StackPanel>
                    </Button>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Height="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}" />
                        <TextBlock Grid.Column="1" Style="{StaticResource BodyLargeStrongTextBlockStyle}" Margin="10,0">Input</TextBlock>
                        <Border Height="1" Grid.Column="2" Background="{ThemeResource SystemControlForegroundBaseLowBrush}" />
                    </Grid>
                    <RelativePanel Height="150">
                        <NumberBox Name="X" Header="X" Width="140" LostFocus="X_OnTextChanged" SpinButtonPlacementMode="Compact" LargeChange="20"/>
                        <NumberBox Name="Y" Header="Y" Width="140" LostFocus="Y_OnTextChanged" RelativePanel.AlignRightWithPanel="True" SpinButtonPlacementMode="Compact" LargeChange="20"/>
                        <NumberBox Name="XDelta" Header="Width" Width="140" LostFocus="XDelta_OnTextChanged" RelativePanel.AlignBottomWithPanel="True"
                                   SpinButtonPlacementMode="Compact" LargeChange="20"/>
                        <NumberBox Name="YDelta" Header="Height" Width="140" LostFocus="YDelta_OnTextChanged" RelativePanel.AlignRightWithPanel="True"
                                   RelativePanel.AlignBottomWithPanel="True" SpinButtonPlacementMode="Compact" LargeChange="20"/>
                    </RelativePanel>
                    <RelativePanel>
                        <CheckBox Name="LockContentAspectRatioCheckBox" IsChecked="True" Content="Lock Aspect Ratio" Checked="LockContentAspectRatioChanged" Unchecked="LockContentAspectRatioChanged"/>
                        <CheckBox Name="LockToCenterCheckBox" IsChecked="True" Content="Lock To Center" Checked="LockToCenterChanged" Unchecked="LockToCenterChanged" RelativePanel.AlignRightWithPanel="True" />
                    </RelativePanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Height="1" Background="{ThemeResource SystemControlForegroundBaseLowBrush}" />
                        <TextBlock Grid.Column="1" Style="{StaticResource BodyLargeStrongTextBlockStyle}" Margin="10,0">Output</TextBlock>
                        <Border Height="1" Grid.Column="2" Background="{ThemeResource SystemControlForegroundBaseLowBrush}" />
                    </Grid>
                    <RelativePanel Height="60">
                        <NumberBox Name="OutputWidth" Header="Output Width" Width="140" LostFocus="OutputWidth_OnLostFocus" RelativePanel.AlignBottomWithPanel="True"
                                   SpinButtonPlacementMode="Compact" LargeChange="20"/>
                        <NumberBox Name="OutputHeight" Header="Output Height" Width="140" LostFocus="OutputHeight_OnLostFocus" RelativePanel.AlignRightWithPanel="True"
                                   RelativePanel.AlignBottomWithPanel="True" SpinButtonPlacementMode="Compact" LargeChange="20"/>
                    </RelativePanel>
                    <CheckBox Name="LockPaddingAspectRatioCheckBox" Content="Lock Aspect Ratio" Checked="LockPaddingAspectRatioChanged" Unchecked="LockPaddingAspectRatioChanged" />
                    <GridView ItemsSource="{x:Bind ratios}">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem" BasedOn="{StaticResource DefaultGridViewItemStyle}">
                                <Setter Property="Margin" Value="5, 5, 5, 5" />
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsWrapGrid MaximumRowsOrColumns="4" Orientation="Horizontal"
                                               HorizontalAlignment="Center" />
                            </ItemsPanelTemplate>
                        </GridView.ItemsPanel>
                        <GridView.ItemTemplate>
                            <DataTemplate x:DataType="local:AspectRatio">
                                <Button Padding="10" Width="70" Height="100" CornerRadius="10" Click="SpecificRatio">
                                    <StackPanel Spacing="10">
                                        <Grid Height="40">
                                            <Rectangle Width="{x:Bind Width}" Height="{x:Bind Height}" Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                                       StrokeThickness="2" RadiusX="3" RadiusY="3" />
                                        </Grid>
                                        <TextBlock HorizontalTextAlignment="Center"
                                                   Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind Title}">
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </StackPanel>
            </ScrollView>
            <controls:HardwareSelector Grid.Row="1" x:Name="HardwareSelector" Margin="0,0,0,10"/>
            <Button HorizontalAlignment="Stretch" Grid.Row="2" Style="{StaticResource AccentButtonStyle}" Click="Pad"
                    IsEnabled="{x:Bind viewModel.DuringOperation, Mode=OneWay, Converter={StaticResource BoolNegationConverter}}">
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Viewbox MaxWidth="30">
                            <FontIcon Glyph="&#xF5AD;" />
                        </Viewbox>
                        <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" HorizontalTextAlignment="Center">Pad!</TextBlock>
                    </StackPanel>
                </Grid>
            </Button>
        </Grid>
    </Grid>
</Page>
